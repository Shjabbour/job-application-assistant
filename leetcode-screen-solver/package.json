  "private": true,
  "description": "Interview Coder is an interview coaching tool that captures coding prompts from screenshots or speech and builds practice-ready solutions.",
  "type": "module",
  "scripts": {
    "watch": "tsx src/index.ts watch",
    "once": "tsx src/index.ts once",

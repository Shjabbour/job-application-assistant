{
  "name": "job-application-assistant",
  "version": "1.0.0",
  "description": "Local CLI assistant for job tracking, application planning, LinkedIn drafts, and Playwright browser capture",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts dashboard --public",
    "start": "tsx src/index.ts dashboard",
    "build": "tsc -p tsconfig.json",
    "chat": "tsx src/index.ts chat",
    "dashboard": "tsx src/index.ts dashboard",
    "cli": "tsx src/index.ts",
    "browser:install": "playwright install chromium",
    "openclaw:bootstrap": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-openclaw-plugin.ps1 -Mode bootstrap",
    "openclaw:cli": "powershell -ExecutionPolicy Bypass -File .\\scripts\\openclaw-cli.ps1",
    "openclaw:plugin:link": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-openclaw-plugin.ps1 -Mode link",
    "openclaw:plugin:install": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-openclaw-plugin.ps1 -Mode install",
    "openclaw:job-assistant": "powershell -ExecutionPolicy Bypass -File .\\scripts\\openclaw-job-assistant.ps1",
    "openclaw:start": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-openclaw-job-assistant.ps1",
    "openclaw:start-save": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-openclaw-job-assistant.ps1 start-save-remote-jobs",
    "openclaw:start-full": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-openclaw-job-assistant.ps1 start-full-autopilot",
    "interview:install": "npm install --prefix leetcode-screen-solver",
    "interview": "npm run native --prefix leetcode-screen-solver",
    "interview:start": "npm run native --prefix leetcode-screen-solver",
    "interview:ui": "npm run ui --prefix leetcode-screen-solver",
    "interview:native": "npm run native --prefix leetcode-screen-solver",
    "interview:native:smoke": "npm run native:smoke --prefix leetcode-screen-solver",
    "test": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
